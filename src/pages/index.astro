---
import Layout from '../layouts/Layout.astro';
import { navLinks, quickFacts, quickLinks } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
	title="Janan & Ryan's Wellington Guide"
	description="Janan and Ryan's guest guide to Wellington: travel tips, wedding-weekend details, and local favorites."
	navLinks={navLinks}
>
	<section class="hero panel">
		<div class="hero-copy">
			<p class="eyebrow">Janan and Ryan's wedding week</p>
			<h1>Welcome to Wellington!</h1>
			<p class="lead">
				You made it to our corner of the world, and we&apos;re so excited to celebrate with you.
				This guide is your Janan-and-Ryan-approved game plan for the trip: what to sort before
				you fly, what to expect when you land, and where to eat, wander, and caffeinate while
				you&apos;re in Wellington.
			</p>
		</div>
		<div class="hero-aside">
			<p>Think of this as your wedding-weekend cheat sheet.</p>
			<strong>Pack layers, bring dancing shoes, and save room for flat whites and breezy waterfront strolls.</strong>
		</div>
	</section>

	<section class="content-grid">
		<div class="quick-links panel">
			<div class="section-heading">
				<p class="eyebrow">Start here</p>
				<h2>Quick links</h2>
			</div>
			<div class="card-grid">
				{quickLinks.map((link) => (
					<a class="card" href={`${base}${link.href.replace(/^\//, '')}`}>
						<strong>{link.label}</strong>
						<span>{link.description}</span>
					</a>
				))}
			</div>
		</div>

		<aside class="facts panel">
			<div class="section-heading">
				<p class="eyebrow">Handy at a glance</p>
				<h2>Quick facts</h2>
			</div>
			<ul>
				{quickFacts.map((fact) => (
					<li>
						<span>{fact.label}</span>
						<strong>{fact.value}</strong>
					</li>
				))}
			</ul>
		</aside>
	</section>

	<style>
		.hero {
			display: grid;
			grid-template-columns: minmax(0, 1.8fr) minmax(260px, 0.9fr);
			gap: 1.5rem;
			padding: 2rem;
			margin-bottom: 1.5rem;
		}

		.hero-copy {
			display: grid;
			gap: 1rem;
		}

		.eyebrow {
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			font-size: 0.8rem;
			font-weight: 700;
			color: var(--action-primary);
		}

		h1,
		h2,
		p {
			margin: 0;
		}

		h1 {
			font-size: clamp(2.7rem, 6vw, 5.25rem);
			line-height: 0.95;
			max-width: 10ch;
		}

		.lead {
			font-size: 1.1rem;
			line-height: 1.7;
			max-width: 60ch;
			color: var(--text-muted);
		}

		.hero-aside {
			display: grid;
			align-content: end;
			gap: 0.9rem;
			padding: 1.4rem;
			border-radius: 22px;
			background: var(--hero-aside-bg);
			color: var(--text-on-accent);
		}

		.hero-aside p {
			color: var(--text-on-accent-muted);
		}

		.content-grid {
			display: grid;
			grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.8fr);
			gap: 1.5rem;
		}

		.quick-links,
		.facts {
			padding: 1.6rem;
		}

		.section-heading {
			display: grid;
			gap: 0.45rem;
			margin-bottom: 1.25rem;
		}

		h2 {
			font-size: 1.7rem;
		}

		.card-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1rem;
		}

		.card {
			display: grid;
			gap: 0.65rem;
			padding: 1.25rem;
			border-radius: 22px;
			background: var(--bg-card);
			border: 1px solid var(--border-content);
			transition:
				transform 180ms ease,
				border-color 180ms ease,
				box-shadow 180ms ease;
		}

		.card strong {
			font-size: 1.05rem;
		}

		.card span {
			line-height: 1.55;
			color: var(--text-muted);
		}

		.card:hover,
		.card:focus-visible {
			transform: translateY(-2px);
			border-color: var(--interactive-border-hover);
			box-shadow: var(--interactive-shadow-hover);
			outline: none;
		}

		.card:focus-visible {
			outline: 3px solid var(--focus-ring);
			outline-offset: 2px;
		}

		.facts ul {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			gap: 0.95rem;
		}

		.facts li {
			display: grid;
			gap: 0.3rem;
			padding-bottom: 0.95rem;
			border-bottom: 1px solid var(--border-subtle);
		}

		.facts li:last-child {
			padding-bottom: 0;
			border-bottom: none;
		}

		.facts span {
			font-size: 0.88rem;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--action-secondary);
		}

		.facts strong {
			font-size: 1.02rem;
			line-height: 1.5;
		}

		@media (max-width: 900px) {
			.hero,
			.content-grid {
				grid-template-columns: 1fr;
			}

			h1 {
				max-width: none;
			}
		}

		@media (max-width: 640px) {
			.hero,
			.quick-links,
			.facts {
				padding: 1.25rem;
			}

			.card-grid {
				grid-template-columns: 1fr;
			}

			.lead {
				font-size: 1rem;
			}
		}
	</style>
</Layout>
