---
import Layout from '../layouts/Layout.astro';
import { navLinks, quickFacts, quickLinks } from '../data/site';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
	title="Welcome to New Zealand | NZ Wedding Guide"
	description="A simple travel guide for wedding guests visiting New Zealand and Wellington."
	navLinks={navLinks}
>
	<section class="hero panel">
		<div class="hero-copy">
			<p class="eyebrow">For our travelling guests</p>
			<h1>Welcome to New Zealand</h1>
			<p class="lead">
				We&apos;re so excited to have you travel so far to celebrate with us. This site is here
				to make the trip feel simple: what to know before you leave, what to expect when you
				land, and how to enjoy Wellington while you&apos;re here.
			</p>
		</div>
		<div class="hero-aside">
			<p>Use this as your wedding-weekend pamphlet.</p>
			<strong>Plan lightly, pack layers, and leave room for good coffee and windy walks.</strong>
		</div>
	</section>

	<section class="content-grid">
		<div class="quick-links panel">
			<div class="section-heading">
				<p class="eyebrow">Start here</p>
				<h2>Quick links</h2>
			</div>
			<div class="card-grid">
				{quickLinks.map((link) => (
					<a class="card" href={`${base}${link.href.replace(/^\//, '')}`}>
						<strong>{link.label}</strong>
						<span>{link.description}</span>
					</a>
				))}
			</div>
		</div>

		<aside class="facts panel">
			<div class="section-heading">
				<p class="eyebrow">Handy at a glance</p>
				<h2>Quick facts</h2>
			</div>
			<ul>
				{quickFacts.map((fact) => (
					<li>
						<span>{fact.label}</span>
						<strong>{fact.value}</strong>
					</li>
				))}
			</ul>
		</aside>
	</section>

	<style>
		.hero {
			display: grid;
			grid-template-columns: minmax(0, 1.8fr) minmax(260px, 0.9fr);
			gap: 1.5rem;
			padding: 2rem;
			margin-bottom: 1.5rem;
		}

		.hero-copy {
			display: grid;
			gap: 1rem;
		}

		.eyebrow {
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			font-size: 0.8rem;
			font-weight: 700;
			color: var(--accent);
		}

		h1,
		h2,
		p {
			margin: 0;
		}

		h1 {
			font-size: clamp(2.7rem, 6vw, 5.25rem);
			line-height: 0.95;
			max-width: 10ch;
		}

		.lead {
			font-size: 1.1rem;
			line-height: 1.7;
			max-width: 60ch;
			color: var(--muted);
		}

		.hero-aside {
			display: grid;
			align-content: end;
			gap: 0.9rem;
			padding: 1.4rem;
			border-radius: 22px;
			background:
				linear-gradient(180deg, rgba(29, 95, 90, 0.92), rgba(24, 76, 73, 0.92)),
				linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent);
			color: #f7f4ef;
		}

		.hero-aside p {
			color: rgba(247, 244, 239, 0.78);
		}

		.content-grid {
			display: grid;
			grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.8fr);
			gap: 1.5rem;
		}

		.quick-links,
		.facts {
			padding: 1.6rem;
		}

		.section-heading {
			display: grid;
			gap: 0.45rem;
			margin-bottom: 1.25rem;
		}

		h2 {
			font-size: 1.7rem;
		}

		.card-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1rem;
		}

		.card {
			display: grid;
			gap: 0.65rem;
			padding: 1.25rem;
			border-radius: 22px;
			background: var(--surface-strong);
			border: 1px solid rgba(29, 95, 90, 0.12);
			transition:
				transform 180ms ease,
				border-color 180ms ease,
				box-shadow 180ms ease;
		}

		.card strong {
			font-size: 1.05rem;
		}

		.card span {
			line-height: 1.55;
			color: var(--muted);
		}

		.card:hover,
		.card:focus-visible {
			transform: translateY(-2px);
			border-color: rgba(29, 95, 90, 0.32);
			box-shadow: 0 18px 32px rgba(29, 95, 90, 0.12);
			outline: none;
		}

		.facts ul {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			gap: 0.95rem;
		}

		.facts li {
			display: grid;
			gap: 0.3rem;
			padding-bottom: 0.95rem;
			border-bottom: 1px solid var(--line);
		}

		.facts li:last-child {
			padding-bottom: 0;
			border-bottom: none;
		}

		.facts span {
			font-size: 0.88rem;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--accent-warm);
		}

		.facts strong {
			font-size: 1.02rem;
			line-height: 1.5;
		}

		@media (max-width: 900px) {
			.hero,
			.content-grid {
				grid-template-columns: 1fr;
			}

			h1 {
				max-width: none;
			}
		}

		@media (max-width: 640px) {
			.hero,
			.quick-links,
			.facts {
				padding: 1.25rem;
			}

			.card-grid {
				grid-template-columns: 1fr;
			}

			.lead {
				font-size: 1rem;
			}
		}
	</style>
</Layout>
