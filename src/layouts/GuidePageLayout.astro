---
import Layout from './Layout.astro';

interface Frontmatter {
	title: string;
	description?: string;
	eyebrow?: string;
	intro?: string;
}

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

const { frontmatter, headings = [] } = Astro.props as {
	frontmatter: Frontmatter;
	headings?: Heading[];
};

const pageSections = headings.filter((heading) => heading.depth === 2);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title={`${frontmatter.title} | NZ Wedding Guide`} description={frontmatter.description}>
	<section class="guide-page panel">
		<header class="guide-hero">
			<p class="eyebrow">{frontmatter.eyebrow ?? 'Guide section'}</p>
			<h1>{frontmatter.title}</h1>
			{frontmatter.intro && <p class="intro">{frontmatter.intro}</p>}

			{pageSections.length > 0 && (
				<nav class="section-nav" aria-label="On this page">
					<p>On this page</p>
					<ol>
						{pageSections.map((section) => (
							<li>
								<a href={`#${section.slug}`}>{section.text}</a>
							</li>
						))}
					</ol>
				</nav>
			)}
		</header>

		<div class="guide-body">
			<div class="prose">
				<slot />
			</div>

			<aside class="page-note" aria-label="How to use this guide">
				<h2>How to use this page</h2>
				<p>Skim the section titles first, then use the sub-cards for the practical details and checklists.</p>
				<a class="back-link" href={base}>Back to home</a>
			</aside>
		</div>
	</section>

	<style>
		.guide-page {
			padding: 2rem;
			display: grid;
			gap: 1.6rem;
		}

		.guide-hero {
			display: grid;
			gap: 1rem;
		}

		.eyebrow {
			margin: 0;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			font-size: 0.8rem;
			font-weight: 700;
			color: var(--action-primary);
		}

		h1,
		p {
			margin: 0;
		}

		h1 {
			font-size: clamp(2.3rem, 5vw, 4rem);
			line-height: 0.98;
			max-width: 14ch;
		}

		.intro {
			max-width: 70ch;
			font-size: 1.06rem;
			line-height: 1.7;
			color: var(--text-muted);
		}

		.section-nav {
			padding: 1rem 1.1rem;
			border-radius: 18px;
			border: 1px solid var(--border-subtle);
			background: var(--bg-card);
			max-width: 42rem;
		}

		.section-nav p {
			margin: 0;
			font-size: 0.82rem;
			font-weight: 700;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: var(--action-primary);
		}

		.section-nav ol {
			margin: 0.6rem 0 0;
			padding-left: 1.2rem;
			display: grid;
			gap: 0.3rem;
		}

		.section-nav a {
			color: var(--text-primary);
			text-decoration: underline;
			text-decoration-color: transparent;
			text-underline-offset: 0.2em;
			transition: text-decoration-color 180ms ease;
		}

		.section-nav a:hover,
		.section-nav a:focus-visible {
			text-decoration-color: var(--action-primary);
			outline: none;
		}

		.guide-body {
			display: grid;
			gap: 1rem;
			grid-template-columns: minmax(0, 1fr) 17rem;
			align-items: start;
		}

		.prose {
			padding: 1.4rem;
			border-radius: 22px;
			background: var(--bg-card);
			border: 1px solid var(--border-content);
			line-height: 1.75;
			color: var(--text-muted);
		}

		.prose :global(h2) {
			margin: 0;
			padding-top: 0.6rem;
			font-size: 1.45rem;
			line-height: 1.2;
			color: var(--text-primary);
		}

		.prose :global(h2 + p) {
			margin-top: 0.55rem;
		}

		.prose :global(h3) {
			margin: 0 0 0.85rem;
			line-height: 1.15;
			color: var(--text-primary);
		}

		.prose :global(h3) {
			font-size: 1.1rem;
			margin-top: 0;
		}

		.prose :global(p),
		.prose :global(ul),
		.prose :global(ol) {
			margin: 0 0 1rem;
		}

		.prose :global(h2 + blockquote),
		.prose :global(h2 + p + blockquote),
		.prose :global(blockquote + blockquote) {
			margin-top: 0.8rem;
		}

		.prose :global(blockquote) {
			margin: 0 0 0.9rem;
			padding: 1rem 1.1rem;
			border-left: 4px solid var(--action-primary);
			border-radius: 12px;
			background: var(--action-primary-soft);
			color: var(--text-primary);
		}

		.prose :global(blockquote p:last-child),
		.prose :global(blockquote ul:last-child),
		.prose :global(blockquote ol:last-child) {
			margin-bottom: 0;
		}

		.prose :global(hr) {
			margin: 1.5rem 0;
			border: none;
			border-top: 1px solid var(--border-subtle);
		}

		.prose :global(ul),
		.prose :global(ol) {
			padding-left: 1.2rem;
		}

		.prose :global(li + li) {
			margin-top: 0.45rem;
		}

		.prose :global(strong) {
			color: var(--text-primary);
		}

		.page-note {
			padding: 1rem;
			border-radius: 18px;
			border: 1px solid var(--border-subtle);
			background: var(--bg-card);
			display: grid;
			gap: 0.8rem;
			position: sticky;
			top: 1rem;
		}

		.page-note h2,
		.page-note p {
			margin: 0;
		}

		.page-note h2 {
			font-size: 1rem;
		}

		.page-note p {
			font-size: 0.95rem;
			line-height: 1.6;
			color: var(--text-muted);
		}

		.back-link {
			width: fit-content;
			padding: 0.8rem 1rem;
			border-radius: 999px;
			background: var(--action-primary-soft);
			color: var(--action-primary);
			font-weight: 600;
			transition:
				transform 180ms ease,
				box-shadow 180ms ease;
		}

		.back-link:hover,
		.back-link:focus-visible {
			transform: translateY(-1px);
			box-shadow: 0 0 0 3px var(--focus-ring);
			outline: none;
		}

		@media (max-width: 980px) {
			.guide-body {
				grid-template-columns: 1fr;
			}

			.page-note {
				position: static;
			}
		}

		@media (max-width: 640px) {
			.guide-page {
				padding: 1.3rem;
			}

			.prose {
				padding: 1.1rem;
			}

			.section-nav {
				padding: 0.9rem;
			}
		}
	</style>
</Layout>